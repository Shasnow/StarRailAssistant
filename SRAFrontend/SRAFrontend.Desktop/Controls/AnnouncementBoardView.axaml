<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:models="clr-namespace:SRAFrontend.Models;assembly=SRAFrontend"
             xmlns:controls="clr-namespace:SRAFrontend.Desktop.Controls"
             x:Class="SRAFrontend.Desktop.Controls.AnnouncementBoardView"
             x:DataType="controls:AnnouncementBoardViewModel"
             Width="600"
             Height="400">
    <Design.DataContext>
        <controls:AnnouncementBoardViewModel />
    </Design.DataContext>
    <suki:BusyArea BusyText="Loading Announcements..." IsBusy="{Binding IsLoading}">
        <!-- ReSharper disable once Xaml.StyleClassNotFound -->
        <TabControl TabStripPlacement="Left" Classes="HorizontalTabs" ItemsSource="{Binding Announcements}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" TextWrapping="Wrap" TextAlignment="Center" Width="100" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate DataType="{x:Type models:Announcement}">
                    <controls:ThemedMarkdownScrollViewer Markdown="{Binding Content}" />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </suki:BusyArea>

</UserControl>
