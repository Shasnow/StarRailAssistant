<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:controls="clr-namespace:SRAFrontend.Controls"
             xmlns:vm="clr-namespace:SRAFrontend.ViewModels"
             xmlns:models="clr-namespace:SRAFrontend.Models"
             x:Class="SRAFrontend.Views.ScriptStorePageView"
             x:DataType="vm:ScriptStorePageViewModel">

    <Grid ColumnDefinitions="220,*" ColumnSpacing="10" Margin="10">

        <!-- 左栏 -->
        <StackPanel Grid.Column="0" Spacing="8">

            <!-- 仓库列表 -->
            <suki:GlassCard>
                <StackPanel Spacing="8">
                    <TextBlock Text="脚本仓库" FontWeight="SemiBold" FontSize="13"/>
                    <ListBox ItemsSource="{Binding Repos}"
                             SelectedItem="{Binding SelectedRepo}"
                             MaxHeight="120">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ScriptRepo">
                                <TextBlock Text="{Binding Name}"
                                           ToolTip.Tip="{Binding Url}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="添加" Classes="Flat" FontSize="12"
                                Command="{Binding OpenAddRepoCommand}"/>
                        <Button Content="删除" Classes="Flat" FontSize="12"
                                Command="{Binding RemoveRepoCommand}"
                                IsEnabled="{Binding SelectedRepo, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </StackPanel>
                    <StackPanel IsVisible="{Binding IsAddRepoOpen}" Spacing="6">
                        <TextBox Text="{Binding NewRepoName}" Watermark="仓库名称（可选）"/>
                        <TextBox Text="{Binding NewRepoUrl}" Watermark="GitHub 地址或 repo.json 直链"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="确认" Classes="Accent" FontSize="12"
                                    Command="{Binding ConfirmAddRepoCommand}"/>
                            <Button Content="取消" Classes="Flat" FontSize="12"
                                    Command="{Binding CloseAddRepoCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </suki:GlassCard>

            <!-- 已安装脚本 -->
            <suki:GlassCard>
                <StackPanel Spacing="8">
                    <TextBlock Text="已安装" FontWeight="SemiBold" FontSize="13"/>
                    <ItemsControl ItemsSource="{Binding InstalledScripts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ScriptManifest">
                                <Border Padding="8,6" Margin="0,0,0,4"
                                        Background="{DynamicResource SukiCardBackground}"
                                        CornerRadius="6">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="2">
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="11" Opacity="0.5">
                                                <Run Text="v"/><Run Text="{Binding Version}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Classes="Flat"
                                                FontSize="11"
                                                Height="24" Padding="6,0"
                                                ToolTip.Tip="查看 README"
                                                Command="{Binding $parent[UserControl].((vm:ScriptStorePageViewModel)DataContext).OpenInstalledReadmeCommand}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="README"/>
                                        </Button>
                                        <Button Grid.Column="1"
                                                Classes="Flat"
                                                FontSize="11"
                                                Height="24" Padding="6,0"
                                                Foreground="OrangeRed"
                                                ToolTip.Tip="卸载"
                                                Command="{Binding $parent[UserControl].((vm:ScriptStorePageViewModel)DataContext).UninstallScriptCommand}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="卸载" Foreground="OrangeRed"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </suki:GlassCard>

        </StackPanel>

        <!-- 右栏：脚本列表 -->
        <suki:GlassCard Grid.Column="1">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                               VerticalAlignment="Center" Opacity="0.6" FontSize="12"/>
                    <Button Grid.Column="1" Content="刷新" Classes="Flat"
                            Command="{Binding FetchRepoScriptsCommand}"
                            IsEnabled="{Binding !IsLoading}"/>
                    <Button Grid.Column="2" Content="检查更新" Classes="Flat"
                            Margin="6,0,0,0"
                            Command="{Binding CheckUpdatesCommand}"
                            IsEnabled="{Binding !IsLoading}"/>
                </Grid>

                <ProgressBar IsVisible="{Binding IsLoading}"
                             Value="{Binding DownloadProgress}"
                             Maximum="100"/>

                <ScrollViewer MaxHeight="580">
                    <ItemsControl ItemsSource="{Binding RepoScripts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:RepoScriptInfo">
                                <Border Padding="12,10" Margin="0,0,0,6"
                                        Background="{DynamicResource SukiCardBackground}"
                                        CornerRadius="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold" FontSize="14"/>
                                                <Border Background="#2080FF30" CornerRadius="4"
                                                        Padding="5,1"
                                                        IsVisible="{Binding HasUpdate}">
                                                    <TextBlock Text="有更新" FontSize="11" Foreground="#40C060"/>
                                                </Border>
                                                <Border Background="#20808080" CornerRadius="4"
                                                        Padding="5,1"
                                                        IsVisible="{Binding IsInstalled}">
                                                    <TextBlock FontSize="11" Opacity="0.7">
                                                        <Run Text="已安装 v"/>
                                                        <Run Text="{Binding InstalledVersion}"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}"
                                                       Opacity="0.65" FontSize="12"
                                                       TextWrapping="Wrap" MaxWidth="500"/>
                                            <TextBlock FontSize="11" Opacity="0.45">
                                                <Run Text="v"/><Run Text="{Binding Version}"/>
                                                <Run Text=" · "/><Run Text="{Binding Author}"/>
                                                <Run Text=" · "/><Run Text="{Binding LastUpdated}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                    Spacing="6" VerticalAlignment="Center">
                                            <Button Content="README" Classes="Flat"
                                                    FontSize="12" Height="32" Padding="10,0"
                                                    ToolTip.Tip="查看说明文档"
                                                    Command="{Binding $parent[UserControl].((vm:ScriptStorePageViewModel)DataContext).OpenReadmeCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Classes="Accent" FontSize="12"
                                                    Height="32" Padding="14,0"
                                                    IsVisible="{Binding !IsInstalled}"
                                                    Command="{Binding $parent[UserControl].((vm:ScriptStorePageViewModel)DataContext).InstallScriptCommand}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="安装"/>
                                            </Button>
                                            <Button Classes="Accent" FontSize="12"
                                                    Height="32" Padding="14,0"
                                                    IsVisible="{Binding HasUpdate}"
                                                    Command="{Binding $parent[UserControl].((vm:ScriptStorePageViewModel)DataContext).InstallScriptCommand}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="更新"/>
                                            </Button>
                                            <Button FontSize="12" Height="32" Padding="14,0"
                                                    IsVisible="{Binding IsInstalled}"
                                                    IsEnabled="False" Classes="Flat">
                                                <TextBlock Text="已安装" Opacity="0.5"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </suki:GlassCard>

    </Grid>
</UserControl>
