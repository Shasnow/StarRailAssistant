<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:lang="clr-namespace:SRAFrontend.Localization"
             xmlns:viewModels="clr-namespace:SRAFrontend.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SRAFrontend.Views.ExtensionPageView"
             x:DataType="viewModels:ExtensionPageViewModel">
    <suki:GlassCard>
        <suki:GroupBox Header="{x:Static lang:Resources.ExtensionText}">
            <Grid ColumnDefinitions="Auto, Auto" RowDefinitions="Auto" ColumnSpacing="12">
                <suki:GlassCard Grid.Column="0" Grid.Row="0" Width="200">
                    <suki:GroupBox Header="自动对话">
                        <Grid ColumnDefinitions="Auto,Auto,*" RowDefinitions="Auto,Auto">
                            <Label Grid.Row="0" Content="启用" />
                            <ToggleSwitch Grid.Row="0" Grid.Column="1" IsChecked="{Binding EnableAutoPlot}"/>
                            <Label Grid.Row="1" Grid.Column="0" Content="跳过对话" />
                            <ToggleSwitch Grid.Row="1" Grid.Column="1" IsChecked="{Binding SkipPlot}"/>
                        </Grid>
                    </suki:GroupBox>
                </suki:GlassCard>
                <suki:GlassCard Grid.Column="1" Grid.Row="0" Width="200">
                    <suki:GroupBox Header="猫猫糕友人帐">
                        <StackPanel Spacing="4">
                            <Label Content="查询对应猫猫糕UID"/>
                            <Button Content="寻找猫猫糕"
                                    Click="Button_OnClick"/>
                        </StackPanel>
                    </suki:GroupBox>
                </suki:GlassCard>
            </Grid>
        </suki:GroupBox>
    </suki:GlassCard>
</UserControl>
