<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:viewModels="clr-namespace:SRAFrontend.ViewModels"
             xmlns:taskViews="clr-namespace:SRAFrontend.Views.TaskViews"
             xmlns:lang="clr-namespace:SRAFrontend.Localization"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="viewModels:TaskPageViewModel"
             x:Class="SRAFrontend.Views.TaskPageView">

    <Border Margin="10">
        <Grid RowDefinitions="Auto, Auto, *">
            <!-- 控制面板 -->
            <suki:GlassCard Content="{Binding ControlPanelViewModel}" />

            <!-- 标签栏行：标签 + 紧贴的 + 按钮，底部下划线 -->
            <Border Grid.Row="1" Margin="0,4,0,0"
                    BorderBrush="{DynamicResource SukiLightBorderBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <!-- 任务标签列表 -->
                    <ItemsControl x:Name="TabHeaderList" ItemsSource="{Binding TaskOrderList}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:TaskOrderItem">
                                <Panel>
                                    <Border IsVisible="{Binding IsFixed}"
                                            Padding="12,6"
                                            Cursor="Hand"
                                            PointerPressed="FixedTabHeader_PointerPressed">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Border IsVisible="{Binding IsMovable}"
                                            CornerRadius="6,6,0,0"
                                            BorderThickness="1,1,1,0"
                                            BorderBrush="{DynamicResource SukiLightBorderBrush}"
                                            Background="{DynamicResource SukiCardBackground}"
                                            Padding="12,6"
                                            Cursor="SizeWestEast"
                                            PointerPressed="TabHeader_PointerPressed"
                                            ToolTip.Tip="左右拖动调整顺序">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Height="3" VerticalAlignment="Bottom"
                                            Background="{DynamicResource SukiAccentColor}"
                                            IsVisible="{Binding IsSelected}"
                                            CornerRadius="2,2,0,0"/>
                                </Panel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- + 紧贴在标签最右侧，和可移动标签样式一致 -->
                    <Button VerticalAlignment="Bottom"
                            CornerRadius="6,6,0,0"
                            BorderThickness="1,1,1,0"
                            BorderBrush="{DynamicResource SukiLightBorderBrush}"
                            Background="{DynamicResource SukiCardBackground}"
                            Padding="10,6"
                            Cursor="Hand"
                            ToolTip.Tip="添加自定义任务"
                            Command="{Binding AddCustomTaskCommand}">
                        <TextBlock Text="+"
                                   FontSize="14"
                                   Opacity="0.5"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 内容区域 -->
            <Grid Grid.Row="2">
                <taskViews:StartGameView
                    IsVisible="{Binding StartGameTaskSelected}"/>
                <taskViews:TrailblazePowerView
                    IsVisible="{Binding TrailblazePowerTaskSelected}"/>
                <taskViews:ReceiveRewardsView
                    IsVisible="{Binding ReceiveRewardsTaskSelected}"/>
                <taskViews:CosmicStrife
                    IsVisible="{Binding CosmicStrifeTaskSelected}"/>
                <taskViews:MissionAccomplishView
                    IsVisible="{Binding MissionAccomplishTaskSelected}"/>
                <taskViews:CustomTaskView
                    IsVisible="{Binding CustomTaskSelected}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
