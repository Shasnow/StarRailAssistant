<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:suki="https://github.com/kikipoulet/SukiUI"
        xmlns:controls="clr-namespace:SRAFrontend.Controls"
        x:Class="SRAFrontend.Views.ReadmeWindow"
        x:DataType="vm:ScriptStorePageViewModel"
        xmlns:vm="clr-namespace:SRAFrontend.ViewModels"
        Title="{Binding ReadmeTitle}"
        Width="820" Height="600"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
    <Grid RowDefinitions="*,Auto" Margin="16">
        <ScrollViewer Grid.Row="0">
            <StackPanel>
                <TextBlock IsVisible="{Binding IsReadmeLoading}"
                           Text="正在加载..."
                           HorizontalAlignment="Center"
                           Margin="0,40"
                           Opacity="0.5" FontSize="14"/>
                <controls:ThemedMarkdownScrollViewer
                    IsVisible="{Binding !IsReadmeLoading}"
                    Markdown="{Binding ReadmeContent}"/>
            </StackPanel>
        </ScrollViewer>
        <Button Grid.Row="1"
                Content="关闭"
                Classes="Flat"
                HorizontalAlignment="Right"
                Margin="0,8,0,0"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
