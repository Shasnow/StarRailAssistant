<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:objectModel="clr-namespace:System.Collections.ObjectModel;assembly=System.ObjectModel"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             xmlns:viewModels="clr-namespace:SRAFrontend.ViewModels"
             xmlns:lang="clr-namespace:SRAFrontend.Localization"
             xmlns:models="clr-namespace:SRAFrontend.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SRAFrontend.Views.SettingsPageView"
             x:DataType="viewModels:SettingsPageViewModel"
             FontSize="16">
    <suki:SukiStackPage>
        <suki:SukiStackPage.Content>
            <suki:SettingsLayout Name="{x:Static lang:Resources.SettingText}">
                <suki:SettingsLayout.Styles>
                    <Style Selector="Label">
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                    <Style Selector="Grid">
                        <Setter Property="ColumnSpacing" Value="10" />
                    </Style>
                </suki:SettingsLayout.Styles>
                <suki:SettingsLayout.Items>
                    <objectModel:ObservableCollection x:TypeArguments="suki:SettingsLayoutItem">
                        <suki:SettingsLayoutItem Header="{x:Static lang:Resources.TaskSettingsText}">
                            <suki:SettingsLayoutItem.Content>
                                <StackPanel>
                                    <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                                        <Label Classes="Icon">&#xe40c;</Label>
                                        <Label Grid.Column="1" Content="{x:Static lang:Resources.GamePathText}" />
                                        <ToggleSwitch OnContent="{x:Static lang:Resources.AutoDetectText}"
                                                      Grid.Column="2"
                                                      IsChecked="{Binding GeneralSettings.IsAutoDetectGamePath}"
                                                      Command="{Binding DetectGamePathCommand}"
                                                      Width="120"
                                                      ToolTip.Tip="开启以自动检测电脑中的游戏" />
                                        <ComboBox Grid.Column="3"
                                                  ItemsSource="{Binding GeneralSettings.GamePaths}"
                                                  SelectedIndex="{Binding GeneralSettings.GamePathIndex}" />
                                        <Button Grid.Column="4" Classes="Icon"
                                                FontFamily="{StaticResource Phosphor}"
                                                Content="&#xE256;"
                                                Command="{Binding SelectedPathCommand}"
                                                IsVisible="{Binding !GeneralSettings.IsAutoDetectGamePath}"
                                                ToolTip.Tip="浏览并选择文件" />
                                    </Grid>
                                    
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Label Classes="Icon">&#xE1AA;</Label>
                                        <Label Grid.Column="1" Content="{x:Static lang:Resources.CloudGameText}" />
                                        <ToggleSwitch Grid.Column="2" IsChecked="{Binding GeneralSettings.IsCloudGameEnable}"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Label Classes="Icon">&#xee60;</Label>
                                        <Label Grid.Column="1" Content="{x:Static lang:Resources.ConfidenceText}" />
                                        <NumericUpDown Grid.Column="2" FormatString="0.00"
                                                       Value="{Binding GeneralSettings.TemplateMatchConfidence}"
                                                       Increment="0.01" Minimum="0"
                                                       Maximum="1" />
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Label Classes="Icon">&#xE0F8;</Label>
                                        <Label Grid.Column="1" Content="启用叠加层" />
                                        <ToggleSwitch Grid.Column="2"
                                                      IsChecked="{Binding IsOverlayEnabled}"/>
                                    </Grid>
                                    <!-- 启动/停止 快捷键（任务通用设置） -->
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Label Classes="Icon">&#xE3E4;</Label>
                                        <Label Grid.Column="1" Content="{x:Static lang:Resources.StopHotkeyText}" />
                                        <Button Grid.Column="2" MinWidth="100"
                                                Content="{Binding StartStopKey.CurrentKey}"
                                                Command="{Binding StartStopKey.ModifyKeyCommand}" />
                                    </Grid>

                                    <Expander Header="游戏启动参数" IsExpanded="True">
                                        <StackPanel>
                                            <!-- 启用开关 -->
                                            <Grid ColumnDefinitions="Auto, *, Auto">
                                                <Label Classes="Icon">&#xE47E;</Label>
                                                <Label Grid.Column="1" Content="启用启动参数" />
                                                <ToggleSwitch Grid.Column="2"
                                                              IsChecked="{Binding GeneralSettings.IsGameArgsEnabled}" />
                                            </Grid>

                                            <!-- 以下控件仅在启用时显示 -->
                                            <StackPanel IsVisible="{Binding GeneralSettings.IsGameArgsEnabled}">
                                                <!-- 窗口尺寸 -->
                                                <Grid ColumnDefinitions="Auto, *, Auto">
                                                    <Label Classes="Icon">&#xED6E;</Label>
                                                    <Label Grid.Column="1" Content="窗口尺寸" />
                                                    <ComboBox Grid.Column="2"
                                                              SelectedItem="{Binding GeneralSettings.GameArgsWindowSize}">
                                                        <system:String>1920x1080</system:String>
                                                    </ComboBox>
                                                </Grid>

                                                <!-- 显示模式 -->
                                                <Grid ColumnDefinitions="Auto, *, Auto">
                                                    <Label Classes="Icon">&#xE626;</Label>
                                                    <Label Grid.Column="1" Content="显示模式" />
                                                    <ComboBox Grid.Column="2"
                                                              SelectedItem="{Binding GeneralSettings.GameArgsFullScreenMode}">
                                                        <system:String>窗口化</system:String>
                                                        <system:String>全屏</system:String>
                                                    </ComboBox>
                                                </Grid>

                                                <!-- 无边框窗口 -->
                                                <Grid ColumnDefinitions="Auto, *, Auto">
                                                    <Label Classes="Icon">&#xE5DA;</Label>
                                                    <Label Grid.Column="1" Content="无边框窗口" />
                                                    <ToggleSwitch Grid.Column="2"
                                                                  IsChecked="{Binding GeneralSettings.IsGameArgsPopupWindow}" />
                                                </Grid>

                                                <!-- 高级参数 -->
                                                <Grid ColumnDefinitions="Auto, *, Auto">
                                                    <Label Classes="Icon">&#xE12C;</Label>
                                                    <Label Grid.Column="1" Content="高级参数" />
                                                    <TextBox Grid.Column="2"
                                                             MinWidth="300"
                                                             Watermark="如果你不知道这是做什么的 请不要填写"
                                                             Text="{Binding GeneralSettings.GameArgsAdvanced}" />
                                                </Grid>
                                            </StackPanel>

                                            <!-- 使用 CMD 启动游戏（不受启用开关影响） -->
                                            <Grid ColumnDefinitions="Auto, *, Auto">
                                                <Label Classes="Icon">&#xE272;</Label>
                                                <Label Grid.Column="1" Content="使用 CMD 启动游戏" />
                                                <ToggleSwitch Grid.Column="2"
                                                              IsChecked="{Binding GeneralSettings.IsUseCmd}" />
                                            </Grid>
                                        </StackPanel>
                                    </Expander>

                                    <Expander Header="{x:Static lang:Resources.HotkeysText}">
                                        <StackPanel>
                                            <TextBlock Text="{x:Static lang:Resources.ModifyHoldText}"
                                                       FontStyle="Italic"
                                                       Margin="0,0,0,8" />
                                            <ItemsControl ItemsSource="{Binding CustomizableKeys}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:CustomizableKey">
                                                        <Grid ColumnDefinitions="Auto, *, Auto, Auto" Margin="0,0,0,4">
                                                            <Label Grid.Column="0" Classes="Icon"
                                                                   Content="{Binding IconText}" />
                                                            <Label Grid.Column="1" Content="{Binding DisplayText}" />
                                                            <Button Grid.Column="2" MinWidth="100"
                                                                    Content="{Binding CurrentKey}"
                                                                    Command="{Binding ModifyKeyCommand}" />
                                                            <Button Grid.Column="3"
                                                                    Classes="Icon"
                                                                    FontFamily="{StaticResource Phosphor}"
                                                                    Content="&#xE036;"
                                                                    Command="{Binding ResetToDefaultCommand}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </suki:SettingsLayoutItem.Content>
                        </suki:SettingsLayoutItem>

                        <suki:SettingsLayoutItem Header="{x:Static lang:Resources.DisplayText}">
                            <suki:SettingsLayoutItem.Content>
                                <StackPanel>
                                    <!-- <Grid ColumnDefinitions="Auto,*,Auto"> -->
                                    <!--     <Label Grid.Column="0" Classes="Icon">&#xe6c8;</Label> -->
                                    <!--     <Label Grid.Column="1" Content="{x:Static lang:Resources.ThemeText}" /> -->
                                    <!--     <ComboBox Grid.Column="2" SelectedIndex="{Binding ThemeSelectedIndex}"> -->
                                    <!--         <ComboBoxItem Content="{x:Static lang:Resources.LightText}" /> -->
                                    <!--         <ComboBoxItem Content="{x:Static lang:Resources.DarkText}" /> -->
                                    <!--     </ComboBox> -->
                                    <!-- </Grid> -->
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Label Grid.Column="0" Classes="Icon" Content="&#xE2CA;" />
                                        <Label Grid.Column="1" Content="{x:Static lang:Resources.BackgroundImageText}" />
                                        <TextBox Grid.Column="2"
                                                 Width="400"
                                                 Watermark="{x:Static lang:Resources.BgImagePathWatermarkText}"
                                                 Text="{Binding DisplaySettings.BackgroundImageUri}" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto, *, Auto, 28">
                                        <Label Grid.Column="0" Classes="Icon" Content="&#xEB42;" />
                                        <Label Grid.Column="1"
                                               Content="{x:Static lang:Resources.BackgroundImageOpacityText}" />
                                        <Slider Grid.Column="2"
                                                Width="200"
                                                Maximum="1"
                                                TickFrequency="0.01"
                                                IsSnapToTickEnabled="True"
                                                Value="{Binding DisplaySettings.BackgroundOpacity}" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding DisplaySettings.BackgroundOpacity}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="DemiBold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto, *, Auto, 28">
                                        <Label Grid.Column="0" Classes="Icon" Content="&#xEB42;" />
                                        <Label Grid.Column="1"
                                               Content="{x:Static lang:Resources.ControlPanelOpacityText}" />
                                        <Slider Grid.Column="2"
                                                Width="200"
                                                Maximum="1"
                                                TickFrequency="0.01"
                                                IsSnapToTickEnabled="True"
                                                Value="{Binding DisplaySettings.ControlPanelOpacity}" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding DisplaySettings.ControlPanelOpacity}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="DemiBold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Label Grid.Column="0" Classes="Icon">&#xe4a2;</Label>
                                        <Label Grid.Column="1" Content="{x:Static lang:Resources.LanguageText}" />
                                        <ComboBox Grid.Column="2" SelectedIndex="{Binding DisplaySettings.Language}">
                                            <ComboBoxItem>简体中文</ComboBoxItem>
                                            <ComboBoxItem>English</ComboBoxItem>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </suki:SettingsLayoutItem.Content>
                        </suki:SettingsLayoutItem>

                        <suki:SettingsLayoutItem Header="{x:Static lang:Resources.RegularText}">
                            <suki:SettingsLayoutItem.Content>
                                <StackPanel>
                                    <Expander Header="{x:Static lang:Resources.NotificationText}"
                                              HorizontalAlignment="Stretch" IsExpanded="False">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Label Classes="Icon">&#xe0ce;</Label>
                                                <Label Grid.Column="1"
                                                       Content="{x:Static lang:Resources.AllowNotificationText}" />
                                                <ToggleSwitch Grid.Column="2"
                                                              IsChecked="{Binding NotificationSettings.IsEnabled}" />
                                            </Grid>
                                            <CheckBox Content="{x:Static lang:Resources.SystemNotificationText}"
                                                      IsChecked="{Binding NotificationSettings.IsSystemEnabled}" />
                                            <Grid ColumnDefinitions="*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          Content="{x:Static lang:Resources.EmailNotificationText}"
                                                          IsChecked="{Binding NotificationSettings.IsEmailEnabled}" />
                                                <Button Grid.Column="1"
                                                        Content="Check"
                                                        Margin="10,0,0,0"
                                                        Command="{Binding TestEmailCommand}"
                                                        IsEnabled="{Binding NotificationSettings.IsEmailEnabled}" />
                                            </Grid>
                                            <Expander Header="{x:Static lang:Resources.SmtpSettingsText}"
                                                      IsVisible="{Binding NotificationSettings.IsEmailEnabled}">
                                                <Grid RowDefinitions="Auto,*,*,*,*" ColumnDefinitions="*,*">
                                                    <Label Grid.Row="0" Grid.Column="0"
                                                           Content="{x:Static lang:Resources.SmtpServerText}" />
                                                    <TextBox Grid.Row="0" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.SmtpServer}"
                                                             Watermark="smtp.qq.com" />
                                                    <Label Grid.Row="1" Grid.Column="0"
                                                           Content="{x:Static lang:Resources.SmtpPortText}" />
                                                    <TextBox Grid.Row="1" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.SmtpPort}"
                                                             Watermark="465" />
                                                    <Label Grid.Row="2" Grid.Column="0"
                                                           Content="{x:Static lang:Resources.SenderEmailAddrText}" />
                                                    <TextBox Grid.Row="2" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.SmtpSender}"
                                                             Watermark="123456@qq.com" />
                                                    <Label Grid.Row="3" Grid.Column="0"
                                                           Content="{x:Static lang:Resources.AuthorCodeText}" />
                                                    <TextBox Grid.Row="3" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.SmtpAuthCode}"
                                                             Watermark="123456" />
                                                    <Label Grid.Row="4" Grid.Column="0"
                                                           Content="{x:Static lang:Resources.ReceiverEmailAddrText}" />
                                                    <TextBox Grid.Row="4" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.SmtpReceiver}"
                                                             Watermark="123456@qq.com" />
                                                </Grid>
                                            </Expander>
                                            <!-- Webhook 通知 -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          Content="Webhook 通知"
                                                          IsChecked="{Binding NotificationSettings.IsWebhookEnabled}" />
                                                <Button Grid.Column="1"
                                                        Content="Check"
                                                        Margin="10,0,0,0"
                                                        Command="{Binding TestWebhookCommand}"
                                                        IsEnabled="{Binding NotificationSettings.IsWebhookEnabled}" />
                                            </Grid>
                                            <Expander Header="Webhook 设置"
                                                      IsVisible="{Binding NotificationSettings.IsWebhookEnabled}">
                                                <Grid RowDefinitions="Auto" ColumnDefinitions="Auto,*">
                                                    <Label Grid.Row="0" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="推送地址" />
                                                    <TextBox Grid.Row="0" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.WebhookUrl}"
                                                             Watermark="https://your-webhook-endpoint" />
                                                </Grid>
                                            </Expander>
                                            <!-- Telegram 通知 -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          Content="Telegram 通知"
                                                          IsChecked="{Binding NotificationSettings.IsTelegramEnabled}" />
                                                <Button Grid.Column="1"
                                                        Content="Check"
                                                        Margin="10,0,0,0"
                                                        Command="{Binding TestTelegramCommand}"
                                                        IsEnabled="{Binding NotificationSettings.IsTelegramEnabled}" />
                                            </Grid>
                                            <Expander Header="Telegram 设置"
                                                      IsVisible="{Binding NotificationSettings.IsTelegramEnabled}">
                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                                      ColumnDefinitions="Auto,*"
                                                      RowSpacing="6">
                                                    <Label Grid.Row="0" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="Bot Token" />
                                                    <TextBox Grid.Row="0" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.TelegramBotToken}"
                                                             Watermark="1234567890:ABCdef..." />
                                                    <Label Grid.Row="1" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="Chat ID" />
                                                    <TextBox Grid.Row="1" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.TelegramChatId}"
                                                             Watermark="-1001234567890" />
                                                    <Label Grid.Row="2" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="自定义 API 地址" />
                                                    <TextBox Grid.Row="2" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.TelegramApiBaseUrl}"
                                                             Watermark="留空使用官方 API" />
                                                    <Label Grid.Row="3" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="启用代理" />
                                                    <ToggleSwitch Grid.Row="3" Grid.Column="1"
                                                                  IsChecked="{Binding NotificationSettings.IsTelegramProxyEnabled}" />
                                                    <Label Grid.Row="4" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding NotificationSettings.IsTelegramProxyEnabled}"
                                                           Content="代理地址" />
                                                    <TextBox Grid.Row="4" Grid.Column="1"
                                                             IsVisible="{Binding NotificationSettings.IsTelegramProxyEnabled}"
                                                             Text="{Binding NotificationSettings.TelegramProxyUrl}"
                                                             Watermark="http://127.0.0.1:7890" />
                                                    <Label Grid.Row="5" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="发送截图" />
                                                    <ToggleSwitch Grid.Row="5" Grid.Column="1"
                                                                  IsChecked="{Binding NotificationSettings.IsTelegramSendImage}"
                                                                  OnContent="开" OffContent="关" />
                                                </Grid>
                                            </Expander>

                                            <!-- ServerChan 通知 -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          Content="ServerChan 微信通知"
                                                          IsChecked="{Binding NotificationSettings.IsServerChanEnabled}" />
                                                <Button Grid.Column="1"
                                                        Content="Check"
                                                        Margin="10,0,0,0"
                                                        Command="{Binding TestServerChanCommand}"
                                                        IsEnabled="{Binding NotificationSettings.IsServerChanEnabled}" />
                                            </Grid>
                                            <Expander Header="ServerChan 设置"
                                                      IsVisible="{Binding NotificationSettings.IsServerChanEnabled}">
                                                <Grid RowDefinitions="Auto" ColumnDefinitions="Auto,*">
                                                    <Label Grid.Row="0" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="SendKey" />
                                                    <TextBox Grid.Row="0" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.ServerChanSendKey}"
                                                             Watermark="SCT... 或 sctp..." />
                                                </Grid>
                                            </Expander>

                                            <!-- OneBot 通知 -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          Content="OneBot QQ 通知"
                                                          IsChecked="{Binding NotificationSettings.IsOneBotEnabled}" />
                                                <Button Grid.Column="1"
                                                        Content="Check"
                                                        Margin="10,0,0,0"
                                                        Command="{Binding TestOneBotCommand}"
                                                        IsEnabled="{Binding NotificationSettings.IsOneBotEnabled}" />
                                            </Grid>
                                            <Expander Header="OneBot 设置"
                                                      IsVisible="{Binding NotificationSettings.IsOneBotEnabled}">
                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                                      ColumnDefinitions="Auto,*"
                                                      RowSpacing="6">
                                                    <Label Grid.Row="0" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="API 地址" />
                                                    <TextBox Grid.Row="0" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.OneBotUrl}"
                                                             Watermark="http://127.0.0.1:3000" />
                                                    <Label Grid.Row="1" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="QQ 号（私聊）" />
                                                    <TextBox Grid.Row="1" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.OneBotUserId}"
                                                             Watermark="留空则不发送私聊" />
                                                    <Label Grid.Row="2" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="群号（群聊）" />
                                                    <TextBox Grid.Row="2" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.OneBotGroupId}"
                                                             Watermark="留空则不发送群聊" />
                                                    <Label Grid.Row="3" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="AccessToken" />
                                                    <TextBox Grid.Row="3" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.OneBotToken}"
                                                             Watermark="留空则不使用认证" />
                                                    <Label Grid.Row="4" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="发送截图" />
                                                    <ToggleSwitch Grid.Row="4" Grid.Column="1"
                                                                  IsChecked="{Binding NotificationSettings.IsOneBotSendImage}"
                                                                  OnContent="开" OffContent="关" />
                                                </Grid>
                                            </Expander>

                                            <!-- Bark 通知 -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          Content="Bark 通知（iOS）"
                                                          IsChecked="{Binding NotificationSettings.IsBarkEnabled}" />
                                                <Button Grid.Column="1"
                                                        Content="Check"
                                                        Margin="10,0,0,0"
                                                        Command="{Binding TestBarkCommand}"
                                                        IsEnabled="{Binding NotificationSettings.IsBarkEnabled}" />
                                            </Grid>
                                            <Expander Header="Bark 设置"
                                                      IsVisible="{Binding NotificationSettings.IsBarkEnabled}">
                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                                      ColumnDefinitions="Auto,*" RowSpacing="6">
                                                    <Label Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="设备 Key" />
                                                    <TextBox Grid.Row="0" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.BarkDeviceKey}"
                                                             Watermark="从 Bark App 复制，多个用逗号分隔" />
                                                    <Label Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="Bark API 端点" />
                                                    <TextBox Grid.Row="1" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.BarkServerUrl}"
                                                             Watermark="https://api.day.app" />
                                                    <Label Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="推送级别" />
                                                    <TextBox Grid.Row="2" Grid.Column="1"
                                                             Text=""
                                                             IsReadOnly="True"
                                                             Watermark="active / timeSensitive / passive" />
                                                    <Label Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="通知声音" />
                                                    <TextBox Grid.Row="3" Grid.Column="1"
                                                             Text=""
                                                             IsReadOnly="True"
                                                             Watermark="minuet（可选）" />
                                                    <Label Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="通知图标" />
                                                    <TextBox Grid.Row="4" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.BarkIcon}"
                                                             Watermark="图标 URL（可选）" />
                                                    <Label Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="通知分组" />
                                                    <TextBox Grid.Row="5" Grid.Column="1"
                                                             Text=""
                                                             IsReadOnly="True"
                                                             Watermark="StarRailAssistant" />
                                                    <Label Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="加密密钥" />
                                                    <TextBox Grid.Row="6" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.BarkCiphertext}"
                                                             Watermark="加密内容（可选）" />
                                                </Grid>
                                            </Expander>

                                            <!-- 飞书通知 -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          Content="飞书通知"
                                                          IsChecked="{Binding NotificationSettings.IsFeishuEnabled}" />
                                                <Button Grid.Column="1"
                                                        Content="Check"
                                                        Margin="10,0,0,0"
                                                        Command="{Binding TestFeishuCommand}"
                                                        IsEnabled="{Binding NotificationSettings.IsFeishuEnabled}" />
                                            </Grid>
                                            <Expander Header="飞书设置"
                                                      IsVisible="{Binding NotificationSettings.IsFeishuEnabled}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="方式一：群机器人 Webhook" FontWeight="Bold" />
                                                    <Grid RowDefinitions="Auto" ColumnDefinitions="Auto,*">
                                                        <Label Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                                               Content="飞书通知地址" />
                                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                                 Text="{Binding NotificationSettings.FeishuWebhookUrl}"
                                                                 Watermark="https://open.feishu.cn/open-apis/bot/v2/hook/..." />
                                                    </Grid>
                                                    <TextBlock Text="方式二：应用 API（可发给指定用户）" FontWeight="Bold"
                                                               Margin="0,6,0,0" />
                                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                                          ColumnDefinitions="Auto,*" RowSpacing="6">
                                                        <Label Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                                               Content="飞书 AppId" />
                                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                                 Text="{Binding NotificationSettings.FeishuAppId}"
                                                                 Watermark="cli_..." />
                                                        <Label Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                                               Content="飞书 AppSecret" />
                                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                                 Text="{Binding NotificationSettings.FeishuAppSecret}"
                                                                 Watermark="应用 AppSecret" />
                                                        <Label Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                                               Content="接收者 ID" />
                                                        <TextBox Grid.Row="2" Grid.Column="1"
                                                                 Text="{Binding NotificationSettings.FeishuReceiveId}"
                                                                 Watermark="open_id / user_id / chat_id" />
                                                        <Label Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"
                                                               Content="ID 类型" />
                                                        <TextBox Grid.Row="3" Grid.Column="1"
                                                                 Text="{Binding NotificationSettings.FeishuReceiveIdType}"
                                                                 Watermark="open_id（默认）" />
                                                    </Grid>
                                                </StackPanel>
                                            </Expander>

                                            <!-- 企业微信通知 -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          Content="企业微信通知"
                                                          IsChecked="{Binding NotificationSettings.IsWeComEnabled}" />
                                                <Button Grid.Column="1"
                                                        Content="Check"
                                                        Margin="10,0,0,0"
                                                        Command="{Binding TestWeComCommand}"
                                                        IsEnabled="{Binding NotificationSettings.IsWeComEnabled}" />
                                            </Grid>
                                            <Expander Header="企业微信设置"
                                                      IsVisible="{Binding NotificationSettings.IsWeComEnabled}">
                                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*">
                                                    <Label Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="Webhook 地址" />
                                                    <TextBox Grid.Row="0" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.WeComWebhookUrl}"
                                                             Watermark="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=..." />
                                                    <Label Grid.Row="1" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="发送截图" />
                                                    <ToggleSwitch Grid.Row="1" Grid.Column="1"
                                                                  IsChecked="{Binding NotificationSettings.IsWeComSendImage}"
                                                                  OnContent="开" OffContent="关" />
                                                </Grid>
                                            </Expander>

                                            <!-- 钉钉通知 -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          Content="钉钉通知"
                                                          IsChecked="{Binding NotificationSettings.IsDingTalkEnabled}" />
                                                <Button Grid.Column="1"
                                                        Content="Check"
                                                        Margin="10,0,0,0"
                                                        Command="{Binding TestDingTalkCommand}"
                                                        IsEnabled="{Binding NotificationSettings.IsDingTalkEnabled}" />
                                            </Grid>
                                            <Expander Header="钉钉设置"
                                                      IsVisible="{Binding NotificationSettings.IsDingTalkEnabled}">
                                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*"
                                                      RowSpacing="6">
                                                    <Label Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="Webhook 地址" />
                                                    <TextBox Grid.Row="0" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.DingTalkWebhookUrl}"
                                                             Watermark="https://oapi.dingtalk.com/robot/send?access_token=..." />
                                                    <Label Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="加签密钥" />
                                                    <TextBox Grid.Row="1" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.DingTalkSecret}"
                                                             Watermark="SEC... （可选）" />
                                                </Grid>
                                            </Expander>

                                            <!-- Discord 通知 -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          Content="Discord Webhook 通知"
                                                          IsChecked="{Binding NotificationSettings.IsDiscordEnabled}" />
                                                <Button Grid.Column="1"
                                                        Content="Check"
                                                        Margin="10,0,0,0"
                                                        Command="{Binding TestDiscordCommand}"
                                                        IsEnabled="{Binding NotificationSettings.IsDiscordEnabled}" />
                                            </Grid>
                                            <Expander Header="Discord 设置"
                                                      IsVisible="{Binding NotificationSettings.IsDiscordEnabled}">
                                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*">
                                                    <Label Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="Webhook 地址" />
                                                    <TextBox Grid.Row="0" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.DiscordWebhookUrl}"
                                                             Watermark="https://discord.com/api/webhooks/..." />
                                                    <Label Grid.Row="1" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Content="发送截图" />
                                                    <ToggleSwitch Grid.Row="1" Grid.Column="1"
                                                                  IsChecked="{Binding NotificationSettings.IsDiscordSendImage}"
                                                                  OnContent="开" OffContent="关" />
                                                </Grid>
                                            </Expander>

                                            <!-- xxtui 通知 -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          Content="xxtui 通知"
                                                          IsChecked="{Binding NotificationSettings.IsXxtuiEnabled}" />
                                                <Button Grid.Column="1"
                                                        Content="Check"
                                                        Margin="10,0,0,0"
                                                        Command="{Binding TestXxtuiCommand}"
                                                        IsEnabled="{Binding NotificationSettings.IsXxtuiEnabled}" />
                                            </Grid>
                                            <Expander Header="xxtui 设置"
                                                      IsVisible="{Binding NotificationSettings.IsXxtuiEnabled}">
                                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*"
                                                      RowSpacing="6">
                                                    <Label Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="API 密钥" />
                                                    <TextBox Grid.Row="0" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.XxtuiApiKey}"
                                                             Watermark="从 xxtui.com 获取" />
                                                    <Label Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="通知来源" />
                                                    <TextBox Grid.Row="1" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.XxtuiSource}"
                                                             Watermark="如 StarRailAssistant（可选）" />
                                                    <Label Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                                           Content="通知渠道" />
                                                    <TextBox Grid.Row="2" Grid.Column="1"
                                                             Text="{Binding NotificationSettings.XxtuiChannel}"
                                                             Watermark="如 WX_MP（可选）" />
                                                </Grid>
                                            </Expander>

                                            <!-- 任务通知配置 -->
                                            <Expander Header="任务通知配置"
                                                      HorizontalAlignment="Stretch">
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="当前版本任务级通知配置已迁移，后续将在新配置结构中提供可视化设置。"
                                                           FontSize="11"
                                                           Opacity="0.7"
                                                           TextWrapping="Wrap" />
                                            </Expander>

                                        </StackPanel>
                                    </Expander>


                                    <!-- <Grid ColumnDefinitions="Auto,*,Auto"> -->
                                    <!-- <Label Grid.Column="0" Classes="Icon">&#xe0f4;</Label> -->
                                    <!-- <Label Grid.Column="1" Content="{x:Static lang:Resources.DefaultPageText}" /> -->
                                    <!-- <ComboBox Grid.Column="2" SelectedIndex="0"> -->
                                    <!-- <ComboBoxItem>Page1</ComboBoxItem> -->
                                    <!-- <ComboBoxItem>Page2</ComboBoxItem> -->
                                    <!-- <ComboBoxItem>Page3</ComboBoxItem> -->
                                    <!-- </ComboBox> -->
                                    <!-- </Grid> -->

                                    <!-- <Grid ColumnDefinitions="Auto,*,Auto" ToolTip.Tip="SRA需要管理员权限，无法使用开机自启，请使用计划任务" > -->
                                    <!--     <Label Classes="Icon">&#xe586;</Label> -->
                                    <!--     <Label Grid.Column="1" Content="{x:Static lang:Resources.StartUpText}"/> -->
                                    <!--     <ToggleSwitch Grid.Column="2" -->
                                    <!--                   IsChecked="{Binding Settings.EnableStartupLaunch}" -->
                                    <!--                   IsEnabled="False" /> -->
                                    <!-- </Grid> -->
                                    <!-- -->
                                    <!-- <Grid ColumnDefinitions="Auto,*,Auto"> -->
                                    <!--     <Label Classes="Icon">&#xe434;</Label> -->
                                    <!--     <Label Grid.Column="1" Content="{x:Static lang:Resources.EnableTrayIconText}" /> -->
                                    <!--     <ToggleSwitch Grid.Column="2" -->
                                    <!--                   IsChecked="{Binding Settings.EnableMinimizeToTray}" -->
                                    <!--                   IsEnabled="False" /> -->
                                    <!-- </Grid> -->
                                    <Button Content="{x:Static lang:Resources.CreateShortcutText}"
                                            HorizontalAlignment="Left"
                                            Command="{Binding CreateDesktopShortcutCommand}" />
                                </StackPanel>
                            </suki:SettingsLayoutItem.Content>
                        </suki:SettingsLayoutItem>

                        <suki:SettingsLayoutItem Header="{x:Static lang:Resources.UpdateText}">
                            <suki:SettingsLayoutItem.Content>
                                <StackPanel>
                                    <Button Content="{x:Static lang:Resources.CheckForUpdateText}"
                                            HorizontalAlignment="Left"
                                            Command="{Binding CheckForUpdatesCommand}" />
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Label Classes="Icon">&#xe094;</Label>
                                        <Label Grid.Column="1"
                                               Content="{x:Static lang:Resources.AutoUpdateText}"
                                               ToolTip.Tip="{x:Static lang:Resources.AutoUpdateTipText}" />
                                        <ToggleSwitch Grid.Column="2" IsChecked="{Binding UpdateSettings.IsAutoUpdate}" />
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto, *, Auto, *">
                                        <Label Classes="Icon">&#xed6a;</Label>
                                        <Label Grid.Column="1"
                                               Content="{x:Static lang:Resources.MirrorChyanText}"
                                               ToolTip.Tip="{x:Static lang:Resources.MirrorChyanTipText}" />
                                        <Button Grid.Column="2" Classes="Icon" Content="&#xE036;"
                                                Command="{Binding VerifyCdkCommand}" />
                                        <StackPanel Grid.Column="3">
                                            <TextBox
                                                Watermark="Enter You CDK"
                                                PasswordChar="*"
                                                Text="{Binding MirrorChyanCdk}" />
                                            <TextBlock Text="{Binding Cache.CdkStatus}"
                                                       Foreground="{Binding Cache.CdkStatusForeground}" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto, *, *">
                                        <Label Classes="Icon">&#xebaa;</Label>
                                        <Label Grid.Column="1" Content="{x:Static lang:Resources.UpdateChannelText}" />
                                        <ComboBox Grid.Column="2" SelectedIndex="{Binding UpdateSettings.DownloadChannel}">
                                            <ComboBoxItem>Mirror 酱</ComboBoxItem>
                                            <ComboBoxItem>GitHub</ComboBoxItem>
                                            <ComboBoxItem>Auto-MAS</ComboBoxItem>
                                        </ComboBox>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto, *, *">
                                        <Label Classes="Icon">&#xe77e;</Label>
                                        <Label Grid.Column="1"
                                               Content="{x:Static lang:Resources.AppChannelText}"
                                               ToolTip.Tip="y" />
                                        <ComboBox Grid.Column="2" SelectedIndex="{Binding UpdateSettings.UpdateChannel}">
                                            <ComboBoxItem>stable</ComboBoxItem>
                                            <ComboBoxItem>beta</ComboBoxItem>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </suki:SettingsLayoutItem.Content>
                        </suki:SettingsLayoutItem>

                        <suki:SettingsLayoutItem Header="{x:Static lang:Resources.AdvanceText}">
                            <suki:SettingsLayoutItem.Content>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="{x:Static lang:Resources.BeLogsFolderText}"
                                                Command="{Binding OpenFolderCommand}"
                                                CommandParameter="backendLogs" />
                                        <Button Content="{x:Static lang:Resources.FeLogsFolder}"
                                                Command="{Binding OpenFolderCommand}"
                                                CommandParameter="frontendLogs" />
                                        <Button Content="{x:Static lang:Resources.ConfigsFolder}"
                                                Command="{Binding OpenFolderCommand}"
                                                CommandParameter="configs" />
                                        <Button Content="{x:Static lang:Resources.AppDataFolder}"
                                                Command="{Binding OpenFolderCommand}"
                                                CommandParameter="appdata" />
                                    </StackPanel>
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Label Classes="Icon">&#xe184;</Label>
                                        <Label Grid.Column="1"
                                               Content="{x:Static lang:Resources.ResourceIntegrityCheckText}" />
                                        <Button Grid.Column="2" IsEnabled="False">Check</Button>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto, Auto, *">
                                        <Label Classes="Icon">&#xe184;</Label>
                                        <Label Grid.Column="1"
                                               Content="后端启动参数" />
                                        <TextBox Grid.Column="2" Text="{Binding AdvancedSettings.BackendLaunchArgs}" Watermark="--inline"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Label Classes="Icon">&#xE47E;</Label>
                                        <Label Grid.Column="1"
                                               Content="{x:Static lang:Resources.UsingPythonText}" />
                                        <ToggleSwitch Grid.Column="2"
                                                      IsChecked="{Binding AdvancedSettings.IsBackendUsePython}" />
                                    </Grid>
                                    <Expander Header="{x:Static lang:Resources.DeveloperOptionsText}"
                                              IsVisible="{Binding AdvancedSettings.IsDeveloperModeEnabled}"
                                              IsExpanded="True">
                                        <StackPanel>
                                            <Grid ColumnDefinitions="Auto, *, Auto">
                                                <Label Classes="Icon">&#xE5F6;</Label>
                                                <Label Grid.Column="1"
                                                       Content="{x:Static lang:Resources.EnableDeveloperOptionsText}" />
                                                <ToggleSwitch Grid.Column="2"
                                                              IsChecked="{Binding AdvancedSettings.IsDeveloperModeEnabled}" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto, *, Auto">
                                                <Label Classes="Icon">&#xE836;</Label>
                                                <Label Grid.Column="1"
                                                       Content="{x:Static lang:Resources.SaveOcrImageText}" />
                                                <ToggleSwitch Grid.Column="2"
                                                              IsChecked="{Binding AdvancedSettings.IsSaveOcrImage}" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto, *, Auto">
                                                <Label Classes="Icon">&#xE7C8;</Label>
                                                <Label Grid.Column="1"
                                                       Content="叠加层显示调试信息" />
                                                <ToggleSwitch Grid.Column="2"
                                                              IsChecked="{Binding IsOverlayDebugInfoEnabled}" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto, *, Auto">
                                                <Label Classes="Icon">&#xE1C2;</Label>
                                                <Label Grid.Column="1"
                                                       Content="{x:Static lang:Resources.PythonInterpreterText}" />
                                                <TextBox Grid.Column="2"
                                                         MinWidth="300"
                                                         Watermark="/path/to/your/python.exe"
                                                         Text="{Binding AdvancedSettings.PythonPath}" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto, *, Auto">
                                                <Label Classes="Icon">&#xEB2C;</Label>
                                                <Label Grid.Column="1" Content="{x:Static lang:Resources.MainPyText}" />
                                                <TextBox Grid.Column="2"
                                                         MinWidth="300"
                                                         Watermark="/path/to/your/main.py"
                                                         Text="{Binding AdvancedSettings.PythonMain}" />
                                            </Grid>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </suki:SettingsLayoutItem.Content>
                        </suki:SettingsLayoutItem>

                        <suki:SettingsLayoutItem Header="{x:Static lang:Resources.AboutText}">
                            <suki:SettingsLayoutItem.Content>
                                <StackPanel>
                                    <!-- ReSharper disable once Xaml.StyleClassNotFound -->
                                    <Button Classes="Basic"
                                            Command="{Binding VersionClickedCommand}">
                                        <TextBlock>版本 / Version : <Run Text="{Binding VersionText}" /></TextBlock>
                                    </Button>
                                    <TextBlock HorizontalAlignment="Center">© 2024-2026 StarRailAssistant, All rights reserved.</TextBlock>
                                    <TextBlock TextWrapping="Wrap" xml:space="preserve">
链接 / Links :
<Grid ColumnDefinitions="*,*,*,*,*,*" RowDefinitions="*,*" ColumnSpacing="20" RowSpacing="10">
    <HyperlinkButton NavigateUri="https://starrailassistant.top" Content="SRA官网" />
    <HyperlinkButton Grid.Row="0" Grid.Column="1" NavigateUri="https://github.com/Shasnow/StarRailAssistant"
                     Content="开放源代码仓库(GitHub)" />
    <HyperlinkButton Grid.Row="0" Grid.Column="2" NavigateUri="https://mirrorchyan.com/zh/get-start?source=sra-about"
                     Content="Mirror 酱" />
    <HyperlinkButton Grid.Row="0" Grid.Column="3" NavigateUri="https://qm.qq.com/q/u6iJ4lUlLW" Content="用户群(QQ)" />
    <HyperlinkButton Grid.Row="0" Grid.Column="4" NavigateUri="https://avaloniaui.net/" Content="Avalonia UI" />
    <HyperlinkButton Grid.Row="0" Grid.Column="5" NavigateUri="https://dotnet.microsoft.com" Content=".NET" />
    <HyperlinkButton Grid.Row="1" Grid.Column="0" NavigateUri="https://www.python.org/" Content="Python" />
</Grid>
                                    </TextBlock>
                                </StackPanel>
                            </suki:SettingsLayoutItem.Content>
                        </suki:SettingsLayoutItem>
                    </objectModel:ObservableCollection>
                </suki:SettingsLayout.Items>
            </suki:SettingsLayout>
        </suki:SukiStackPage.Content>
    </suki:SukiStackPage>
</UserControl>